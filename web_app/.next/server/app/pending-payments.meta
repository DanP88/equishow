{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pending-payments/layout,_N_T_/pending-payments/page,_N_T_/pending-payments"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pending-payments/__PAGE__",
    "/pending-payments",
    "/_index",
    "/_head"
  ]
}