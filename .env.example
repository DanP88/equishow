# ─────────────────────────────────────────────────────────────────────────────
# Equishow — Variables d'environnement (TEMPLATE)
#
# ⚠️ SECURITY: Never commit real .env file to git
# Copy this file to .env.local and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# SUPABASE - Database & Auth
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_REAL_ANON_KEY

# Environment Configuration
APP_ENV=development   # development | staging | production

# SENTRY - Error Tracking (Production only)
# Get DSN from: https://sentry.io/settings/YOUR_ORG/projects/
SENTRY_DSN=https://key@sentry.io/project_id

# REDIS - Rate Limiting (Optional, for production)
# REDIS_URL=redis://localhost:6379
# REDIS_TOKEN=your_upstash_token

# ⚠️ NEVER IN THIS FILE (Server-side only):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   ← Backend/CI only, NEVER in client code
# Database passwords
# Private API keys
# Secret tokens

# 📋 Setup Instructions:
# 1. Copy file: cp .env.example .env.local
# 2. Edit .env.local with real values from Supabase dashboard
# 3. Add .env.local to .gitignore (already done)
# 4. In CI/CD, use GitHub Secrets or environment variables
# 5. NEVER commit .env or .env.local to git
