# ═════════════════════════════════════════════════════════════════════════════
# 🔐 EQUISHOW - CONFIGURATION SÉCURISÉE
# ═════════════════════════════════════════════════════════════════════════════
#
# ⚠️ RÈGLES DE SÉCURITÉ CRITIQUES:
# 1. JAMAIS commiter le vrai .env dans git (inclus dans .gitignore ✓)
# 2. Ne remplir qu'EN LOCAL ou via GitHub Secrets en CI/CD
# 3. Rotation des secrets tous les 3 mois
# 4. Audit des accès secrets
# 5. SERVICE_ROLE_KEY = GitHub Secrets SEULEMENT (jamais en client)
#
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 📍 SUPABASE - Base de données & Authentification
# ─────────────────────────────────────────────────────────────────────────────
# Obtenir depuis: Supabase Dashboard → Settings → API
# Ne jamais partager ces clés!

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_REAL_KEY

# ─────────────────────────────────────────────────────────────────────────────
# 🌍 ENVIRONNEMENT
# ─────────────────────────────────────────────────────────────────────────────
# development = Logs verbose, rate limiting désactivé, Sentry minimal
# staging = Comme production avec données de test
# production = Mode sécurisé, logs minimal, tous les contrôles activés

APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# 📊 MONITORING & ERROR TRACKING
# ─────────────────────────────────────────────────────────────────────────────
# Sentry: Pour tracker les erreurs en production
# Obtenir depuis: https://sentry.io/

SENTRY_DSN=https://key@sentry.io/project_id

# ─────────────────────────────────────────────────────────────────────────────
# 🔴 NE JAMAIS METTRE DANS CE FICHIER:
# ─────────────────────────────────────────────────────────────────────────────
# ✗ SUPABASE_SERVICE_ROLE_KEY (Backend/CI seulement, via GitHub Secrets)
# ✗ Database passwords
# ✗ Private API keys
# ✗ Secret tokens
# ✗ Stripe SECRET key (publishable seulement en client)
# ✗ Credentials de personnes

# ─────────────────────────────────────────────────────────────────────────────
# 📋 SETUP INSTRUCTIONS
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copier: cp .env.example .env
# 2. Remplir AVEC VOS VRAIES VALEURS depuis Supabase Dashboard
# 3. ✓ .env est dans .gitignore
# 4. En CI/CD: utiliser GitHub Secrets (Settings → Secrets and variables)
# 5. JAMAIS commiter .env avec des secrets réels
