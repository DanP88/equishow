# 🚀 Equishow Environment Configuration

# ═══════════════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════
# Get these from https://app.supabase.com/project/wdhgsuulsuwdrtbvetaf/settings/api

# Supabase URL (ends with .supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Public Key (safe to expose in client)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ⚠️ NEVER expose in .env (GitHub Secrets only for CI/CD):
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ═══════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# API Base URL
EXPO_PUBLIC_API_URL=https://api.equishow.local

# API Timeout (ms)
EXPO_PUBLIC_API_TIMEOUT=30000

# ═══════════════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════

# Session timeout (ms)
SESSION_TIMEOUT=3600000

# Enable debug logging
DEBUG_AUTH=false

# ═══════════════════════════════════════════════════════════════════════
# MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════════════

# Sentry DSN for error tracking
EXPO_PUBLIC_SENTRY_DSN=

# Environment (development, staging, production)
EXPO_PUBLIC_ENVIRONMENT=development

# Enable detailed logging
EXPO_PUBLIC_DEBUG_LOGS=true

# ═══════════════════════════════════════════════════════════════════════
# STRIPE PAYMENT
# ═══════════════════════════════════════════════════════════════════════

# Stripe Publishable Key
EXPO_PUBLIC_STRIPE_KEY=pk_test_...

# ═══════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in the values from your Supabase dashboard:
#    - Go to https://app.supabase.com/project/wdhgsuulsuwdrtbvetaf/settings/api
#    - Copy SUPABASE_URL and ANON_KEY
#
# 3. IMPORTANT: .env is in .gitignore - never commit it!
#
# 4. For local development, restart Expo:
#    expo start --clear
#
# ═══════════════════════════════════════════════════════════════════════
